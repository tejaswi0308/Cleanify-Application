<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_image">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Header Title -->
        <TextView
            android:id="@+id/title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Edit Profile"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:gravity="center"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="10dp"/>

        <!-- Profile Image Circle -->
        <FrameLayout
            android:id="@+id/profileFrame"
            android:layout_width="110dp"
            android:layout_height="110dp"
            app:layout_constraintTop_toBottomOf="@id/title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="20dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/circle_bg"
                android:padding="25dp"
                android:src="@android:drawable/sym_def_app_icon"/>

            <!-- Small camera icon -->
            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="bottom|end"
                android:background="@drawable/camera_circle"
                android:padding="6dp"
                android:src="@android:drawable/ic_menu_camera"/>
        </FrameLayout>

        <!-- Change Photo Button -->
        <Button
            android:id="@+id/changePhoto"
            android:layout_width="140dp"
            android:layout_height="40dp"
            android:text="Change Photo"
            android:textAllCaps="false"
            android:textColor="@color/text_white"
            android:backgroundTint="@color/button_blue"
            app:layout_constraintTop_toBottomOf="@id/profileFrame"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="10dp"/>

        <!-- FULL NAME LABEL -->
        <TextView
            android:id="@+id/nameLabel"
            android:text="FULL NAME"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            app:layout_constraintTop_toBottomOf="@id/changePhoto"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="20dp"
            android:layout_height="20dp" android:layout_width="300dp"/>

        <!-- FULL NAME FIELD -->
        <EditText
            android:id="@+id/fullName"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:text="Neha Sharma"
            android:background="@drawable/input_bg_rounded"
            android:padding="14dp"
            android:drawableStart="@android:drawable/ic_menu_myplaces"
            android:drawablePadding="10dp"
            app:layout_constraintTop_toBottomOf="@id/nameLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- EMAIL -->
        <TextView
            android:id="@+id/emailLabel"
            android:text="EMAIL ADDRESS"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            app:layout_constraintTop_toBottomOf="@id/fullName"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="24dp" android:layout_height="20dp"
            android:layout_width="300dp"/>

        <EditText
            android:id="@+id/email"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:text="neha.sharma@xyz.edu.in"
            android:background="@drawable/input_bg_rounded"
            android:padding="14dp"
            android:drawableStart="@android:drawable/ic_dialog_email"
            android:drawablePadding="10dp"
            app:layout_constraintTop_toBottomOf="@id/emailLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- PHONE -->
        <TextView
            android:text="PHONE NUMBER"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            app:layout_constraintTop_toBottomOf="@id/email"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="24dp"
            android:layout_height="20dp"
            android:layout_width="300dp"/>

        <EditText
            android:id="@+id/phone"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:text="+91 12345 67890"
            android:background="@drawable/input_bg_rounded"
            android:padding="14dp"
            android:drawableStart="@android:drawable/ic_menu_call"
            android:drawablePadding="10dp"
            app:layout_constraintTop_toBottomOf="@id/email"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="43dp"/>

        <!-- SERVICE LOCATION -->
        <TextView
            android:text="SERVICE LOCATION"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            app:layout_constraintTop_toBottomOf="@id/phone"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="24dp"
            android:layout_width="300dp"
            android:layout_height="20dp"/>

        <!-- HOSTEL -->
        <EditText
            android:id="@+id/hostel"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:text="KCH"
            android:background="@drawable/input_bg_rounded"
            android:padding="14dp"
            app:layout_constraintTop_toBottomOf="@id/phone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/room"
            android:layout_marginTop="42dp"
            android:layout_marginEnd="8dp"/>

        <!-- ROOM -->
        <EditText
            android:id="@+id/room"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:text="904"
            android:background="@drawable/input_bg_rounded"
            android:padding="14dp"
            app:layout_constraintTop_toBottomOf="@id/phone"
            app:layout_constraintStart_toEndOf="@id/hostel"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="42dp"
            android:layout_marginStart="8dp"/>

        <!-- SAVE BUTTON -->
        <Button
            android:id="@+id/saveBtn"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:text="Save Changes"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textColor="@color/text_white"
            android:backgroundTint="@color/button_blue"
            app:layout_constraintTop_toBottomOf="@id/hostel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="30dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>